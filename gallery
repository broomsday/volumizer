#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DB_PATH="${VOLUMIZER_GALLERY_DB:-data/gallery.db}"

log() {
  echo "[gallery] $*" >&2
}

usage() {
  cat <<EOF
Usage: ./gallery [RUN_PATH] [--force-index] [--force-thumbnails] [--progress-interval SECONDS] [--jobs N] [--render-backend MODE] [--axis-render-mode MODE] [--worker-timeout-seconds SECONDS] [--timing-jsonl PATH] [--host HOST] [--port PORT]

Rebuild the gallery index, render missing thumbnails, and serve the web UI.

  RUN_PATH  Path to a run directory or run.summary.json file.
            If omitted, the run under data/runs/ with the most files is used.

Options:
  --force-index        Rebuild the index even if it is up to date
  --force-thumbnails   Re-render all thumbnails even if they already exist
  --progress-interval  Seconds between thumbnail progress updates (default: 30)
  --jobs               Parallel thumbnail render workers (default: 1)
  --render-backend     software, hardware, or auto (default: software)
  --axis-render-mode   compatibility or fast (default: compatibility)
  --worker-timeout-seconds  Max seconds per thumbnail job before termination (default: 0, disabled)
  --timing-jsonl       Optional JSONL path for structured thumbnail timing output
  --host HOST          Host to bind the server to (default: 127.0.0.1)
  --port PORT          Port to bind the server to (default: 8000)
  -h, --help           Show this help message
EOF
}

# --- Parse arguments ---
RUN_PATH=""
FORCE_INDEX=false
FORCE_THUMBNAILS=false
PROGRESS_INTERVAL="30"
JOBS="1"
RENDER_BACKEND="software"
AXIS_RENDER_MODE="compatibility"
WORKER_TIMEOUT_SECONDS="0"
TIMING_JSONL=""
HOST="127.0.0.1"
PORT="8000"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --force-index)
      FORCE_INDEX=true
      shift
      ;;
    --force-thumbnails)
      FORCE_THUMBNAILS=true
      shift
      ;;
    --progress-interval)
      PROGRESS_INTERVAL="${2:?--progress-interval requires a value}"
      shift 2
      ;;
    --jobs)
      JOBS="${2:?--jobs requires a value}"
      shift 2
      ;;
    --render-backend)
      RENDER_BACKEND="${2:?--render-backend requires a value}"
      shift 2
      ;;
    --axis-render-mode)
      AXIS_RENDER_MODE="${2:?--axis-render-mode requires a value}"
      shift 2
      ;;
    --worker-timeout-seconds)
      WORKER_TIMEOUT_SECONDS="${2:?--worker-timeout-seconds requires a value}"
      shift 2
      ;;
    --timing-jsonl)
      TIMING_JSONL="${2:?--timing-jsonl requires a value}"
      shift 2
      ;;
    --host)
      HOST="${2:?--host requires a value}"
      shift 2
      ;;
    --port)
      PORT="${2:?--port requires a value}"
      shift 2
      ;;
    *)
      RUN_PATH="$1"
      shift
      ;;
  esac
done

# --- Resolve summary file ---
resolve_summary() {
  local path="$1"

  # If it's a file, use it directly
  if [[ -f "$path" ]]; then
    echo "$path"
    return
  fi

  # If it's a directory, look for run.summary.json inside it
  if [[ -d "$path" ]]; then
    local summary="$path/run.summary.json"
    if [[ -f "$summary" ]]; then
      echo "$summary"
      return
    fi
    echo "Error: No run.summary.json found in $path" >&2
    exit 1
  fi

  echo "Error: Path does not exist: $path" >&2
  exit 1
}

if [[ -n "$RUN_PATH" ]]; then
  SUMMARY_PATH="$(resolve_summary "$RUN_PATH")"
else
  # Pick the run directory with the most files
  RUNS_DIR="$SCRIPT_DIR/data/runs"
  if [[ ! -d "$RUNS_DIR" ]]; then
    echo "Error: No runs directory found at $RUNS_DIR" >&2
    exit 1
  fi

  BEST_DIR=""
  BEST_COUNT=0
  for dir in "$RUNS_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    count=$(find "$dir" -maxdepth 1 -type f | wc -l)
    if [[ "$count" -gt "$BEST_COUNT" ]]; then
      BEST_COUNT="$count"
      BEST_DIR="$dir"
    fi
  done

  if [[ -z "$BEST_DIR" ]]; then
    echo "Error: No run directories found in $RUNS_DIR" >&2
    exit 1
  fi

  SUMMARY_PATH="$(resolve_summary "$BEST_DIR")"
  log "auto-selected run: $(basename "$BEST_DIR") ($BEST_COUNT files)"
fi

# --- Step 1: Rebuild gallery index (skip if up to date) ---
NEED_REBUILD=true
if [[ "$FORCE_INDEX" == false && -f "$DB_PATH" ]]; then
  if [[ "$DB_PATH" -nt "$SUMMARY_PATH" ]]; then
    NEED_REBUILD=false
    log "index: up to date ($(basename "$DB_PATH") newer than $(basename "$SUMMARY_PATH")), skipping rebuild"
  fi
fi

if [[ "$NEED_REBUILD" == true ]]; then
  log "index: rebuilding from $SUMMARY_PATH"
  rm -f "$DB_PATH"
  uv run python -m volumizer.gallery_index \
    --summary "$SUMMARY_PATH" \
    --db "$DB_PATH" \
    --skip-structure-metrics \
    --progress-every 500
fi

# --- Step 2: Render thumbnails (skips existing unless --force-thumbnails) ---
log "thumbnails: rendering (skipping up-to-date unless forced)"
THUMBNAIL_ARGS=(
  --db "$DB_PATH"
  --progress-interval "$PROGRESS_INTERVAL"
  --jobs "$JOBS"
  --render-backend "$RENDER_BACKEND"
  --axis-render-mode "$AXIS_RENDER_MODE"
  --worker-timeout-seconds "$WORKER_TIMEOUT_SECONDS"
)
if [[ "$FORCE_THUMBNAILS" == true ]]; then
  THUMBNAIL_ARGS+=(--force)
fi
if [[ -n "$TIMING_JSONL" ]]; then
  THUMBNAIL_ARGS+=(--timing-jsonl "$TIMING_JSONL")
fi
uv run python -m volumizer.gallery_render "${THUMBNAIL_ARGS[@]}"

# --- Step 3: Serve the gallery ---
log "server: starting at http://$HOST:$PORT"
uv run python -m volumizer.web.app --db "$DB_PATH" --host "$HOST" --port "$PORT"
