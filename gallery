#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DB_PATH="${VOLUMIZER_GALLERY_DB:-$SCRIPT_DIR/data/gallery.db}"
PYTHON_VERSION="${VOLUMIZER_GALLERY_PYTHON_VERSION:-3.11}"

PYTHON_RUNNER=()
PYTHON_RUNNER_LABEL=""

log() {
  echo "[gallery] $*" >&2
}

fail() {
  log "error: $*"
  exit 1
}

usage() {
  cat <<EOF
Usage: ./gallery [RUN_PATH] [--force-index] [--force-thumbnails] [--skip-thumbnails] [--progress-interval SECONDS] [--jobs N] [--render-backend MODE] [--axis-render-mode MODE] [--worker-timeout-seconds SECONDS] [--timing-jsonl PATH] [--host HOST] [--port PORT]

Rebuild the gallery index, render missing thumbnails, and serve the web UI.

  RUN_PATH  Path to a run directory or run.summary.json file.
            If omitted, the run under data/runs/ with the most files is used.

Options:
  --force-index        Rebuild the index even if it is up to date
  --force-thumbnails   Re-render all thumbnails even if they already exist
  --skip-thumbnails    Skip new thumbnail rendering, relink existing cached thumbnails, and serve placeholders for missing ones
  --progress-interval  Seconds between thumbnail progress updates (default: 30)
  --jobs               Parallel thumbnail render workers (default: 1)
  --render-backend     software, hardware, or auto (default: software)
  --axis-render-mode   compatibility or fast (default: compatibility)
  --worker-timeout-seconds  Max seconds per thumbnail job before termination (default: 0, disabled)
  --timing-jsonl       Optional JSONL path for structured thumbnail timing output
  --host HOST          Host to bind the server to (default: 127.0.0.1)
  --port PORT          Port to bind the server to (default: 8000)
  -h, --help           Show this help message
EOF
}

select_python_runner() {
  if command -v uv >/dev/null 2>&1; then
    PYTHON_RUNNER=(uv run --group web --python "$PYTHON_VERSION" python)
    PYTHON_RUNNER_LABEL="uv run --group web --python ${PYTHON_VERSION} python"
    return
  fi

  local python_candidate="${VOLUMIZER_GALLERY_PYTHON:-}"
  if [[ -z "$python_candidate" ]]; then
    if command -v python >/dev/null 2>&1; then
      python_candidate="python"
    elif command -v python3 >/dev/null 2>&1; then
      python_candidate="python3"
    else
      fail "no Python interpreter found. Install uv or set VOLUMIZER_GALLERY_PYTHON."
    fi
  fi

  if ! command -v "$python_candidate" >/dev/null 2>&1; then
    fail "configured Python interpreter is unavailable: $python_candidate"
  fi

  PYTHON_RUNNER=("$python_candidate")
  PYTHON_RUNNER_LABEL="$python_candidate"
}

run_python_module() {
  local module_name="$1"
  shift
  (cd "$SCRIPT_DIR" && "${PYTHON_RUNNER[@]}" -m "$module_name" "$@")
}

ensure_python_gallery_deps() {
  if (cd "$SCRIPT_DIR" && "${PYTHON_RUNNER[@]}" -c "import fastapi, uvicorn, volumizer") >/dev/null 2>&1; then
    return
  fi

  fail "Python gallery dependencies are missing. Run 'bash scripts/bootstrap_linux.sh' or install the web dependencies in the active environment."
}

ensure_molstar_assets() {
  if [[ ! -f "$SCRIPT_DIR/node_modules/molstar/build/viewer/molstar.js" || ! -f "$SCRIPT_DIR/node_modules/molstar/build/viewer/molstar.css" ]]; then
    fail "Mol* viewer assets are missing under node_modules. Run 'bash scripts/bootstrap_linux.sh' or 'npm ci'."
  fi
}

ensure_thumbnail_renderer_deps() {
  if ! command -v node >/dev/null 2>&1; then
    fail "Node.js is required for thumbnail rendering. Run 'bash scripts/bootstrap_linux.sh' or install node/npm."
  fi

  if [[ ! -f "$SCRIPT_DIR/node_modules/playwright/package.json" ]]; then
    fail "Playwright is not installed under node_modules. Run 'bash scripts/bootstrap_linux.sh' or 'npm ci'."
  fi

  ensure_molstar_assets
}

ensure_playwright_browser() {
  local check_script='import fs from "node:fs"; import { chromium } from "playwright"; const executablePath = chromium.executablePath(); if (!executablePath || !fs.existsSync(executablePath)) { process.exit(1); }'
  if (cd "$SCRIPT_DIR" && node --input-type=module -e "$check_script") >/dev/null 2>&1; then
    return
  fi

  fail "Playwright Chromium is not installed. Run 'bash scripts/bootstrap_linux.sh' or 'npm run gallery:install-browser'."
}

# --- Parse arguments ---
RUN_PATH=""
FORCE_INDEX=false
FORCE_THUMBNAILS=false
SKIP_THUMBNAILS=false
PROGRESS_INTERVAL="30"
JOBS="1"
RENDER_BACKEND="software"
AXIS_RENDER_MODE="compatibility"
WORKER_TIMEOUT_SECONDS="0"
TIMING_JSONL=""
HOST="127.0.0.1"
PORT="8000"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --force-index)
      FORCE_INDEX=true
      shift
      ;;
    --force-thumbnails)
      FORCE_THUMBNAILS=true
      shift
      ;;
    --skip-thumbnails)
      SKIP_THUMBNAILS=true
      shift
      ;;
    --progress-interval)
      PROGRESS_INTERVAL="${2:?--progress-interval requires a value}"
      shift 2
      ;;
    --jobs)
      JOBS="${2:?--jobs requires a value}"
      shift 2
      ;;
    --render-backend)
      RENDER_BACKEND="${2:?--render-backend requires a value}"
      shift 2
      ;;
    --axis-render-mode)
      AXIS_RENDER_MODE="${2:?--axis-render-mode requires a value}"
      shift 2
      ;;
    --worker-timeout-seconds)
      WORKER_TIMEOUT_SECONDS="${2:?--worker-timeout-seconds requires a value}"
      shift 2
      ;;
    --timing-jsonl)
      TIMING_JSONL="${2:?--timing-jsonl requires a value}"
      shift 2
      ;;
    --host)
      HOST="${2:?--host requires a value}"
      shift 2
      ;;
    --port)
      PORT="${2:?--port requires a value}"
      shift 2
      ;;
    *)
      RUN_PATH="$1"
      shift
      ;;
  esac
done

select_python_runner
log "python runner: $PYTHON_RUNNER_LABEL"
ensure_python_gallery_deps

# --- Resolve summary file ---
make_absolute_path() {
  local raw_path="$1"
  if [[ "$raw_path" = /* ]]; then
    printf '%s\n' "$raw_path"
    return
  fi

  local parent_dir
  parent_dir="$(cd "$(dirname "$raw_path")" && pwd)"
  printf '%s/%s\n' "$parent_dir" "$(basename "$raw_path")"
}

resolve_summary() {
  local path="$1"

  # If it's a file, use it directly
  if [[ -f "$path" ]]; then
    make_absolute_path "$path"
    return
  fi

  # If it's a directory, look for run.summary.json inside it
  if [[ -d "$path" ]]; then
    local summary="$path/run.summary.json"
    if [[ -f "$summary" ]]; then
      make_absolute_path "$summary"
      return
    fi
    echo "Error: No run.summary.json found in $path" >&2
    exit 1
  fi

  echo "Error: Path does not exist: $path" >&2
  exit 1
}

if [[ -n "$RUN_PATH" ]]; then
  SUMMARY_PATH="$(resolve_summary "$RUN_PATH")"
else
  # Pick the run directory with the most files
  RUNS_DIR="$SCRIPT_DIR/data/runs"
  if [[ ! -d "$RUNS_DIR" ]]; then
    echo "Error: No runs directory found at $RUNS_DIR" >&2
    exit 1
  fi

  BEST_DIR=""
  BEST_COUNT=0
  for dir in "$RUNS_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    count=$(find "$dir" -maxdepth 1 -type f | wc -l)
    if [[ "$count" -gt "$BEST_COUNT" ]]; then
      BEST_COUNT="$count"
      BEST_DIR="$dir"
    fi
  done

  if [[ -z "$BEST_DIR" ]]; then
    echo "Error: No run directories found in $RUNS_DIR" >&2
    exit 1
  fi

  SUMMARY_PATH="$(resolve_summary "$BEST_DIR")"
  log "auto-selected run: $(basename "$BEST_DIR") ($BEST_COUNT files)"
fi

DB_PATH="$(make_absolute_path "$DB_PATH")"
if [[ -n "$TIMING_JSONL" ]]; then
  TIMING_JSONL="$(make_absolute_path "$TIMING_JSONL")"
fi

# --- Step 1: Rebuild gallery index (skip if up to date) ---
NEED_REBUILD=true
if [[ "$FORCE_INDEX" == false && -f "$DB_PATH" ]]; then
  if [[ "$DB_PATH" -nt "$SUMMARY_PATH" ]]; then
    NEED_REBUILD=false
    log "index: up to date ($(basename "$DB_PATH") newer than $(basename "$SUMMARY_PATH")), skipping rebuild"
  fi
fi

if [[ "$NEED_REBUILD" == true ]]; then
  log "index: rebuilding from $SUMMARY_PATH"
  rm -f "$DB_PATH"
  run_python_module volumizer.gallery_index \
    --summary "$SUMMARY_PATH" \
    --db "$DB_PATH" \
    --progress-every 500
fi

# --- Step 2: Render thumbnails (skips existing unless --force-thumbnails) ---
if [[ "$SKIP_THUMBNAILS" == true ]]; then
  ensure_molstar_assets
  log "thumbnails: skipped (--skip-thumbnails); relinking any cached thumbnails already on disk"
  run_python_module volumizer.gallery_render \
    --db "$DB_PATH" \
    --reuse-existing-only \
    --progress-interval 0
else
  ensure_thumbnail_renderer_deps
  ensure_playwright_browser

  log "thumbnails: rendering (skipping up-to-date unless forced)"
  THUMBNAIL_ARGS=(
    --db "$DB_PATH"
    --progress-interval "$PROGRESS_INTERVAL"
    --jobs "$JOBS"
    --render-backend "$RENDER_BACKEND"
    --axis-render-mode "$AXIS_RENDER_MODE"
    --worker-timeout-seconds "$WORKER_TIMEOUT_SECONDS"
  )
  if [[ "$FORCE_THUMBNAILS" == true ]]; then
    THUMBNAIL_ARGS+=(--force)
  fi
  if [[ -n "$TIMING_JSONL" ]]; then
    THUMBNAIL_ARGS+=(--timing-jsonl "$TIMING_JSONL")
  fi
  run_python_module volumizer.gallery_render "${THUMBNAIL_ARGS[@]}"
fi

# --- Step 3: Serve the gallery ---
log "server: starting at http://$HOST:$PORT"
run_python_module volumizer.web.app --db "$DB_PATH" --host "$HOST" --port "$PORT"
